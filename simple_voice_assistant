# Display ssd1306
display:
  - platform: ssd1306_i2c
    id: display_id
    model: "SSD1306 128x64"
    update_interval: 200ms    
    lambda: |-
      // -------------------------------------------------------
      // 1. GELBER HEADER-BEREICH (Pixel 0–15)
      // -------------------------------------------------------

      // Icons rechts (jeweils 16x16)
      if (wifi::global_wifi_component->is_connected())
        it.image(112, 0, id(icon_wifi));
      if (api::global_api_server->is_connected())
        it.image(96, 0, id(icon_api));
      if (id(hw_speaker)->get_mute_state())
        it.image(80, 0, id(icon_mute));
      if (id(hw_microphone)->get_mute_state())
        it.image(64, 0, id(icon_deaf));

      // Trennlinie zwischen GELB (oben) und BLAU (unten)
      it.line(0, 16, 128, 16);


      // -------------------------------------------------------
      // 2. BLAUER CONTENT-BEREICH (Pixel 16–63)
      // -------------------------------------------------------
      //it.filled_rectangle(0, 16, 128, 48, COLOR_OFF);


      // -------------------------------------------------------
      // 3. CONTENT ENGINE
      // -------------------------------------------------------
      // Positionen
      constexpr int y0 = 46;
      constexpr int y1 = 30;
      constexpr int y2 = 56;
      constexpr int xc = 64;

      switch (id(content_mode)) {

        // -----------------------------------------
        // -1: Bootscreen
        // -----------------------------------------
        case -1: {
          it.print(0, 0, id(font_medium), "BOOTING");
          it.image(42, 20, id(logo_esphome));
          it.printf(xc, y2, id(font_medium), TextAlign::CENTER,
                    "%s",
                    "${version}" );
          break;
        }

        // -------------------------
        // 0: IDLE
        // -------------------------
        case 0: {
          it.print(0, 0, id(font_medium), "INFO");
          int page_duration = id(page_info_duration).state * 1000;
          int active_subpage = (esphome::millis() / page_duration) % 6;

          static const char* wdays[]    = {"So", "Mo", "Di", "Mi", "Do", "Fr", "Sa"};
          static const char* weekdays[] = {"Sonntag", "Montag", "Dienstag", "Mittwoch", "Donnerstag", "Freitag", "Samstag"};

          auto t = id(esptime).now();
          float temp  = id(room_temp).state;
          float hum   = id(room_hum).state;
          float press = id(room_press).state;


          switch (active_subpage) {

          // -------------------------------------------------
          // 0.0: Uhrzeit
          // -------------------------------------------------
          case 0:
            it.printf(xc, y0, id(font_huge), TextAlign::CENTER,
                      "%02d:%02d",
                      t.hour, t.minute);
            break;

          // -------------------------------------------------
          // 0.1: Datum
          // -------------------------------------------------
          case 1:
            it.printf(xc, y0, id(font_huge), TextAlign::CENTER,
                      "%02d.%02d.%02d",
                      t.day_of_month, t.month, t.year % 100);
            break;

          // -------------------------------------------------
          // 0.2: Wochentag
          // -------------------------------------------------
          case 2:
            it.printf(xc, y0, id(font_large), TextAlign::CENTER,
                      "%s",
                      weekdays[t.day_of_week]);
            break;

          // -------------------------------------------------
          // 0.3: Temp / Press & Hum
          // -------------------------------------------------
          case 3:
            it.printf(xc, y0, id(font_huge), TextAlign::CENTER, 
                      "%.1f°C",
                      temp);
            break;

          // -------------------------------------------------
          // 0.4: Hum / Temp & Press
          // -------------------------------------------------
          case 4:
            it.printf(xc, y0, id(font_huge), TextAlign::CENTER,
                      "%.0f%%rF",
                      hum);
            break;

          // -------------------------------------------------
          // 0.5: Press / Temp & Hum
          // -------------------------------------------------
          case 5:
            it.printf(xc, y0, id(font_huge), TextAlign::CENTER,
                      "%'.0fhPa",
                      press);
            break;
          }
          break;
        }

        // -------------------------
        // 1: LISTENING
        // -------------------------
        case 1:
          it.print(0, 0, id(font_medium), "LISTEN");
          it.printf(xc+16, y1, id(font_medium), TextAlign::CENTER, "Listening...");
          it.image(0, 32, id(icon_listening));          
          it.circle(110, 54, (millis() / 200) % 6 + 2);
          break;

        // -------------------------
        // 2: THINKING
        // -------------------------
        case 2:
          it.print(0, 0, id(font_medium), "THINKING");
          it.printf(xc+16, y1, id(font_medium), TextAlign::CENTER, "Thinking...");
          it.image(0, 32, id(icon_thinking));          
          it.filled_circle(110, 54, (millis() / 200) % 6 + 2);
          break;

        // -------------------------
        // 3: SPEAKING (TTS)
        // -------------------------
        case 3:
          it.print(0, 0, id(font_medium), "SPEAKING");
          it.printf(xc+16, y1, id(font_medium), TextAlign::CENTER, "Speaking...");
          it.image(0, 32, id(icon_speaking));          
          for (int i = 0; i < 5; i++) {
            int h = (sin((millis() / 150.0) + i) + 1) * 8;
            it.filled_rectangle(40 + i * 16, 60 - h, 10, h);
          }
          break;

        // -------------------------
        // 4: VOLUME OVERLAY
        // -------------------------
        case 4: {
          it.print(0, 0, id(font_medium), "VOLUME");
          int vol = id(hw_speaker)->get_volume() * 100;
          it.printf(xc+16, y1, id(font_medium), TextAlign::CENTER, "VOL %d%%", vol);
          it.image(0, 32, id(icon_volume));
          it.filled_rectangle(40, 50, vol / 2, 14);
          break;
        }

        // -------------------------
        // 5: ERROR OVERLAY
        // -------------------------
        case 5: {
          it.print(0, 0, id(font_medium), "ERROR");
          it.image(0, 32, id(icon_error));
          it.printf(xc, y1, id(font_medium), TextAlign::CENTER, "%s", id(error_message));
          break;
        }

      }

voice_assistant:
  id: va
  micro_wake_word:
  use_wake_word: False
  # microphone: hw_microphone
  microphone:
    - microphone: hw_microphone
      channels: 0
    - microphone: hw_microphone
      channels: 1  
  speaker: hw_speaker

  auto_gain: 31dBFS
  noise_suppression_level: 2
  volume_multiplier: 4.0

  on_client_connected:
    - logger.log: "voice_assistant on_client_connect"
    - micro_wake_word.start:

  on_client_disconnected: 
    - logger.log: "voice_assistant on_client_disconnect"
    - micro_wake_word.stop: 
      
  on_wake_word_detected: 
    - logger.log: "voice_assistant on_wake_word_detected"

  on_listening:
    - logger.log: "voice_assistant on_Listening"
    # VA hört zu → Listening (1)
    - script.execute:
        id: set_mode
        mode: 1

  on_start: 
    - logger.log: "voice_assistant on_start"

  ######################################## stt ################################
  # Ende der Sprachantwort
  on_stt_end:
    - lambda: 
        id(text_message) = "Q:"+x;
    - logger.log:
        format: "voice_assistant on_stt_end: %s"
        args: [id(text_message).c_str()]
    # Spracheingabe beendet → Thinking (2)
    - script.execute:
        id: set_mode
        mode: 2

  on_stt_vad_start: 
    - logger.log: "voice_assistant on_vad_start"
  on_stt_vad_end: 
    - logger.log: "voice_assistant on_stt_vad_end"

  ######################################### tts ################################
  on_tts_start: 
    - lambda: 
        id(text_message) = "A:"+x;
    - logger.log:
        format: "voice_assistant on_tts_start: %s"
        args: [id(text_message).c_str()]

  on_tts_stream_start:
    - logger.log: "voice_assistant on_tts_stream_start"
    # TTS spricht → Speaking (3)
    - script.execute:
        id: set_mode
        mode: 3

  on_tts_stream_end:
    - logger.log: "voice_assistant on_tts_stream_end"
    # TTS fertig → zurück zu Idle (0)
    - script.execute:
        id: set_mode
        mode: 0
    # Restart only mWW if enabled; streaming wake words automatically restart
    - micro_wake_word.start:

  on_tts_end: 
    - lambda: 
        id(text_message) = "URL:"+x;
    - logger.log:
        format: "voice_assistant on_tts_end: %s"
        args: [id(text_message).c_str()]

  on_idle: 
    - logger.log: "voice_assistant on_idle"
    # # nix zu tun → zurück zu Idle (0)
    # - script.execute:
    #     id: set_mode
    #     mode: 0

  on_end: 
    - logger.log: "voice_assistant on_end"
            
  on_error:
    - logger.log:
        format: "voice_assistant on_error %d %s"
        args: [code, message.c_str()]
    # Fehler → erst zurück zu Idle (0), dann zu Error(5), der geht dann zurück auf idle(0)
    - script.execute:
        id: set_mode
        mode: 0
    - script.execute:
        id: show_error_overlay
        msg: !lambda |
          return code + ": " + message;

  on_intent_start: 
    - logger.log: "voice_assistant on_intent_start"
  on_intent_progress: 
    - logger.log:
        format: "voice_assistant on_intent_progress %s"
        args: [x.c_str()]
  on_intent_end: 
    - logger.log: "voice_assistant on_intent_end"

  on_timer_started: 
    - logger.log: "voice_assistant on_timer_started"
  on_timer_finished: 
    - logger.log: "voice_assistant on_timer_finished"
  on_timer_cancelled: 
    - logger.log: "voice_assistant on_timer_cancelled"
  on_timer_tick: 
    - logger.log: "voice_assistant on_timer_tick"
  on_timer_updated: 
    - logger.log: "voice_assistant on_timer_updated"
          
              
      

micro_wake_word:
  on_wake_word_detected:
    - logger.log: "micro_wake_word on_wake_word_detected"
    - voice_assistant.start:
        wake_word: !lambda return wake_word;
  
  vad:
  models:
    - model: okay_nabu
      id: okay_nabu
    - model: hey_mycroft
      id: hey_mycroft
    - model: hey_jarvis
      id: hey_jarvis

#################################################################################
# Functions
#################################################################################

# content_mode
#-1 = Boot
# 0 = Idle
# 1 = Listening
# 2 = Thinking
# 3 = Speaking
# 4 = Volume Overlay
# 5 = Error Overlay

# globals - Application Variablen
globals:
  - id: content_mode
    type: int
    initial_value: "-1" # Boot
  - id: error_message
    type: std::string
    initial_value: ""
  - id: text_message
    type: std::string
    initial_value: ""

# configuration - Bedienelemente im HA - Gerät
button:
  - platform: restart
    id: restart_button
    name: "Restart Device"
number:
  - platform: template
    id: volume_number
    name: "Volume"
    min_value: 0
    max_value: 100
    step: 5
    optimistic: true
    set_action:
      - lambda: |-
          id(hw_speaker)->set_volume(int(x) / 100);     // interne Lautstärke setzen
          id(show_volume_overlay).execute();  // Overlay anzeigen
  - platform: template
    id: page_info_duration
    name: "Info Speed"
    entity_category: config
    min_value: 15
    max_value: 300
    step: 15
    initial_value: 60
    optimistic: true
    restore_value: True
  - platform: template
    id: content_mode_number
    name: "Content Mode"
    entity_category: diagnostic
    min_value: -1
    max_value: 5
    step: 1
    optimistic: true
    set_action:
      - lambda: |-
          id(set_mode).execute(int(x));

# Zentrale Stelle für Systemreaktionen
script:
  - id: set_mode
    parameters:
      mode: int
    then:
      - logger.log:
          format: "script set_mode %d"
          args: [mode]
      - lambda: |- 
          // Mode setzen
          id(content_mode) = mode;

          // HA synchronisieren
          id(content_mode_number).publish_state(mode);

          // LED-Effekt auswählen (neue Namen)
          std::string effect = "Effect Mode " + std::to_string(mode);
          auto call = id(hw_leds).turn_on();
          call.set_effect(effect.c_str());
          call.perform();

          // Display aktualisieren
          id(display_id).update();
  - id: show_volume_overlay
    mode: restart
    then:
      - logger.log:
          format: "script show_volume_overlay"
      - lambda: |-
          constexpr int SCHEDULER_ID = 42;

          // persistent zwischen Aufrufen, aber NICHT ins Lambda capturen
          static int saved_mode = -1;

          // Nur sichern, wenn wir NICHT bereits im Volume-Overlay sind
          if (id(content_mode) != 4) {
            saved_mode = id(content_mode);
          }

          // Volume hat Priorität über alles außer Error
          if (id(content_mode) < 4) {
            id(set_mode).execute(4);
          }
          // automatische Kopie für das Lambda erzeugen
          int restore_mode = saved_mode;

          // Timer für overlay beenden setzen
          id(display_id).cancel_timeout(SCHEDULER_ID);
          id(display_id).set_timeout(SCHEDULER_ID, 5000, [restore_mode]() {
            ESP_LOGD("show_volume_overlay", "Timer beendet");
            // Nur zurückspringen, wenn Volume noch aktiv ist
            if (id(content_mode) == 4 && restore_mode != -1) {
              id(set_mode).execute(restore_mode);
